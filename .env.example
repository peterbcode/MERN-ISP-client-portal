# Next.js / API routes
# Copy to `.env.local` for local development.

# MongoDB (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/mern-isp-portal
# If your Atlas URI does not include a database name (ends with `.mongodb.net/?...`),
# set this (defaults to `mern-isp-portal` if omitted).
MONGODB_DBNAME=mern-isp-portal

# Auth
JWT_SECRET=change-me-in-dev
JWT_EXPIRE=7d

# Optional
# Leave NEXT_PUBLIC_API_URL empty on Vercel unless you are using a separate external API.
# The production app uses its own Next.js API routes at /api by default.
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_GA_ID=
DEBUG_API_ERRORS=false
ADMIN_IP_ALLOWLIST=
ADMIN_MUTATIONS_ENABLED=false
ADMIN_ROLE_CHANGES_ENABLED=false

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# CONTACT_EMAIL=info@valley-computers.co.za

# Optional mailing-list notification webhook. Newsletter signups are stored in
# MongoDB when MONGODB_URI is configured; this webhook can also notify your CRM,
# Make/Zapier flow, Slack, or another mailing-list tool.
NEWSLETTER_WEBHOOK_URL=

# App URL for email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
